# Claude-to-IM Bridge 配置模板
# 复制到 ~/.claude-to-im/config.env 并填入真实值
# chmod 600 ~/.claude-to-im/config.env

CTI_RUNTIME=claude
CTI_ENABLED_CHANNELS=feishu,weixin
CTI_DEFAULT_WORKDIR=/Users/YOUR_USERNAME/.clawd
CTI_DEFAULT_MODE=code
CTI_AUTO_APPROVE=true

# 飞书应用凭证（从 open.feishu.cn 开发者后台获取）
CTI_FEISHU_APP_ID=your_app_id_here
CTI_FEISHU_APP_SECRET=your_app_secret_here

# 飞书目标群名（模糊匹配，防止多群时发错；留空则发第一个群）
CTI_FEISHU_CHAT_NAME=

# 指向 wrapper（硬路由 + wiki 预加载）
CTI_CLAUDE_CODE_EXECUTABLE=/Users/YOUR_USERNAME/.clawd/claude-wrapper.sh
